void setup_wifi(){
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(300);
  }
}

bool wifiConnection(){
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi not conected.");
    return false;
  }
  else {return true;}
}
